# ==============================================================================
# NexTarget Backend - Environment Variables
# ==============================================================================
# Copiez ce fichier en .env et complétez les valeurs

# ==============================================================================
# JWT Configuration (REQUIRED)
# ==============================================================================
# Secret key for signing JWT tokens - MUST be strong in production (min 32 chars)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change_me_generate_long_random_min_32_chars

# Token expiration times (optional, defaults provided)
# ACCESS_TOKEN_EXP_MINUTES=60        # Long-lived token for API calls (default: 60 min)
# CALLBACK_TOKEN_EXP_MINUTES=10      # Short-lived token for OAuth redirect (default: 10 min)
# REFRESH_TOKEN_EXP_DAYS=30          # Refresh token lifetime (NT-048, default: 30 days)

# ==============================================================================
# Logging (NT-053)
# ==============================================================================
# Niveau du logger applicatif JSON (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ==============================================================================
# CORS (NT-065)
# ==============================================================================
# Comma-separated list of allowed browser origins.
# Unset (default): "*" in dev, NO origins outside dev (mobile app unaffected:
# native HTTP calls don't send an Origin header).
# Only set this if a web client exists.
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com

# ==============================================================================
# Google OAuth Configuration (REQUIRED for Google login)
# ==============================================================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Type: Web application)
# 2. Add authorized redirect URI
# 3. Copy Client ID and Client Secret

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Redirect URI (must match Google Console configuration)
# Development: http://localhost:8000/auth/google/callback
# Production: https://api.nextarget.app/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ==============================================================================
# Facebook OAuth Configuration (Optional)
# ==============================================================================
# Get credentials from: https://developers.facebook.com/apps

FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# ==============================================================================
# Database Configuration (Optional)
# ==============================================================================
# Development (SQLite - default)
# DATABASE_URL=sqlite:///./data.db

# Production (PostgreSQL - recommended)
# DATABASE_URL=postgresql://user:password@host:5432/database
